{
  "name": "aim-display",
  "productName": "Aim Display",
  "version": "1.0.5",
  "main": "electron/main.js",
  "author": {
    "name": "Hugo Eribon",
    "url": "https://hugoeribon.fr/"
  },
  "description": "Une plateforme complète pour organiser, suivre, diffuser et analyser vos compétitions de tir sportif.",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:ng": "ng build --configuration production",
    "build:electron": "ng build --configuration production --base-href ./",
    "electron:dev": "concurrently -k -s first -n \"NG,ELECTRON\" -c \"bgBlue.bold,bgMagenta.bold\" \"ng serve --host=localhost --port=4200\" \"wait-on http://localhost:4200 && cross-env ELECTRON_OPEN_DEVTOOLS=1 electron .\"",
    "electron:prod": "npm run build:electron && electron .",
    "pack": "npm run build:electron && electron-builder --dir",
    "dist": "npm run build:electron && electron-builder -wml",
    "dist:win": "npm run build:electron && electron-builder --win",
    "dist:mac": "npm run build:electron && electron-builder --mac",
    "dist:linux": "npm run build:electron && electron-builder --linux"
  },
  "build": {
    "appId": "com.example.aimdisplay",
    "protocols": [
      {
        "name": "AimDisplay Links",
        "schemes": [
          "aimdisplay"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/icons/logo.ico",
      "artifactName": "Aim-Display-Setup-${version}.${ext}",
      "publish": [
        {
          "provider": "generic",
          "url": "https://hugoeribon.fr/assets/aim-display/"
        }
      ]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/icons/logo.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "electron/icons/icon.png"
    },
    "nsis": {
      "shortcutName": "Aim Display"
    }
  },
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@primeng/themes": "^21.0.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tailwindcss/postcss": "^4.2.2",
    "axios": "^1.14.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "iconify-icon": "^3.0.2",
    "overlayscrollbars": "^2.14.0",
    "pdfmake": "^0.3.7",
    "postcss": "^8.5.8",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.0",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.24",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~5.1.0",
    "@types/pdfmake": "^0.2.11",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1",
    "icon-gen": "^5.0.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.3",
    "typescript": "~5.9.3",
    "wait-on": "^8.0.4"
  }
}
